# Server Configuration
NODE_ENV="development"
PORT="6001"
# Url of the host where this app is running
OCPI_HOST="https://nearly-boss-pheasant.ngrok-free.app"
# Database (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Can be left empty if you want to use docker DB
DATABASE_URL="postgresql://username:password@host.docker.internal:5432/ubc_ocpi_adaptor?schema=public"

# JWT Secret for Admin Authentication
# IMPORTANT: Generate a strong random string (min 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET="your-secret-key-change-in-production-min-32-characters"
JWT_EXPIRES_IN="24h"
# CDS (Catalog Discover Service) Configuration
CDS_BASE_URL="https://cds.example.com"
CDS_API_KEY="your-cds-api-key"
# Logging Configuration
LOG_LEVEL="info"
CLOUD_PROVIDER="local"
# for UBC
EV_CHARGING_UBC_BPP_ID="pulseenergy-ubc-local-bpp"
EV_CHARGING_UBC_UNIQUE_ID="76EU7ncBX74BMNTQJMcMYoTMSzU7k71owUF53fN4jdxmosxZrdjdDk"
# BPP
EV_CHARGING_UBC_BPP_CLIENT_HOST="http://localhost:7082"
PRIVATE_KEY="uwFYm3LY2wo/G9hjDMrc8v4xbdbQkJrBLOj85q0I1cLBl+T1cm0IH6A4Nl+I5BpHt0ajFMWS/cD4tsiB1m46JQ=="

# Whether to sign callback requests (true/false)
SHOULD_SIGN_CALLBACK_REQUESTS="true"
